<div class="giscus-container">
  <script>
    function loadGiscus() {
      // Remove existing giscus iframe if it exists
      const existingFrame = document.querySelector('iframe.giscus-frame');
      if (existingFrame) {
        existingFrame.remove();
      }
      
      // Create and load the giscus script
      const script = document.createElement('script');
      script.src = 'https://giscus.app/client.js';
      script.dataset.repo = 'Zetsukae/zetsukae.com';
      script.dataset.repoId = 'R_kgDORf6KTw';
      script.dataset.category = 'General';
      script.dataset.categoryId = 'DIC_kwDORf6KT84C30ZG';
      script.dataset.mapping = 'pathname';
      script.dataset.strict = '0';
      script.dataset.reactionsEnabled = '1';
      script.dataset.emitMetadata = '0';
      script.dataset.inputPosition = 'bottom';
      script.dataset.theme = 'preferred_color_scheme';
      script.dataset.lang = 'fr';
      script.crossOrigin = 'anonymous';
      script.async = true;
      
      const container = document.querySelector('.giscus-container');
      if (container) {
        container.appendChild(script);
      }
    }
    
    // Load giscus on initial page load
    loadGiscus();
    
    // Reload giscus on page transitions (Astro View Transitions)
    document.addEventListener('astro:page-load', loadGiscus);
  </script>
</div>
